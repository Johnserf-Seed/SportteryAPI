# Copy to .env (git-ignored). Auto-loaded by the MCP server and smoke test via
# `node --env-file-if-exists=.env ...`.

# API key used by the REST smoke test (must match the Worker's API_KEY secret).
# Leave unset if the Worker has no API_KEY (auth disabled).
API_KEY=

# Base URL for the REST smoke test (defaults to http://localhost:8787).
# BASE=https://sporttery-api.<your-subdomain>.workers.dev

# Optional HTTP proxy for the node-side sporttery fetch (MCP server), e.g. a
# local clash/v2ray proxy. Leave unset if your network can reach the upstream directly.
# SPORTTERY_PROXY=http://127.0.0.1:7890
