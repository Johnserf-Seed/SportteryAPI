{
  "name": "sporttery-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker REST API that turns the China Sports Lottery (体彩竞彩足球) odds calculator into a callable odds-derivation service.",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "refresh-sample": "node --experimental-strip-types scripts/refresh-sample.ts",
    "mcp": "node --env-file-if-exists=.env --no-warnings --experimental-strip-types mcp/server.ts",
    "mcp:smoke": "node --no-warnings --experimental-strip-types scripts/mcp-smoke.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250906.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^6.21.0",
    "zod": "^3.25.76"
  }
}
